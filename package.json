{
  "name": "agent-flywheel-console",
  "version": "0.1.1",
  "description": "Local control plane for the agentic coding flywheel — CLI + dashboard for orchestrating Plan → Beads → Swarm → Review → Deploy on a remote ACFS VPS over SSH.",
  "type": "module",
  "bin": {
    "flywheel": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx cli/index.ts",
    "build": "esbuild cli/index.ts --bundle --platform=node --target=node20 --outfile=dist/cli.js --format=esm --packages=external",
    "dashboard": "vite dashboard",
    "build:dashboard": "vite build dashboard",
    "serve": "tsx cli/index.ts serve",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run test/unit/**/*.test.ts",
    "test:integration": "vitest run test/integration/**/*.test.ts",
    "test:live": "FLYWHEEL_TEST_LIVE=1 vitest run test/live/providers-smoke.test.ts test/live/wizard-provider-path.e2e.ts --testTimeout 300000",
    "test:e2e": "FLYWHEEL_TEST_E2E=1 vitest run test/e2e/**/*.e2e.ts --testTimeout 60000",
    "test:e2e:local": "vitest run test/e2e/local-commands.e2e.ts --testTimeout 30000",
    "test:surface": "tsx scripts/coverage-surface.ts",
    "test:surface:strict": "tsx scripts/coverage-surface.ts --strict"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^8.3.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "node-ssh": "^13.2.0",
    "openai": "^4.80.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "vitest": "^4.0.18"
  }
}
