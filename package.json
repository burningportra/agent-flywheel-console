{
  "name": "agent-flywheel-console",
  "version": "0.1.0",
  "description": "Local control plane for the agentic coding flywheel — CLI + dashboard for orchestrating Plan → Beads → Swarm → Review → Deploy on a remote ACFS VPS over SSH.",
  "type": "module",
  "bin": {
    "flywheel": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx cli/index.ts",
    "build": "esbuild cli/index.ts --bundle --platform=node --target=node20 --outfile=dist/cli.js --format=esm --external:better-sqlite3 --external:node-ssh --external:ssh2",
    "dashboard": "npm --prefix dashboard run dev",
    "build:dashboard": "npm --prefix dashboard run build",
    "serve": "tsx cli/index.ts serve",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "node-ssh": "^13.2.0",
    "openai": "^4.80.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.0"
  }
}
